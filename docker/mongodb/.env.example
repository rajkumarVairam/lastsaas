# MongoDB credentials
MONGO_USER=lastsaas
MONGO_PASS=change-me-strong-password
MONGO_DB=lastsaas

# Backup retention (days)
BACKUP_RETAIN_DAYS=7

# Optional: Cloudflare R2 offsite backup
# Leave blank to skip — backups are still kept locally under mongo_backups volume
S3_BUCKET=
S3_ENDPOINT=                         # https://<account_id>.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
